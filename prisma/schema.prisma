// prisma/schema.prisma
// AgentQuest MVP schema (event-sourced)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// --- Core domain ---

enum AgentRole {
  gm
  player
  observer
}

enum SessionStatus {
  created
  active
  paused
  stopped
}

enum CampaignStatus {
  active
  archived
}

model Campaign {
  id                   BigInt         @id @default(autoincrement()) @db.BigInt
  name                 String         @db.VarChar(200)
  description          String         @default("") @db.VarChar(2000)
  minPlayers           Int            @default(2)
  maxPlayers           Int            @default(6)
  autoStart            Boolean        @default(true)
  status               CampaignStatus @default(active)
  rightsStatus         String         @default("screening_evidence_recorded") @db.VarChar(64)
  contentPolicyVersion String         @default("original-or-authorized-v2") @db.VarChar(64)

  // Campaign configuration. We keep this immutable for MVP by not providing any update endpoint
  // once sessions exist for the campaign.
  settings Json @default("{}")

  createdAt  DateTime  @default(now())
  archivedAt DateTime?

  sessions       Session[]
  characters     Character[]
  agents         Agent[]
  events         Event[]
  invites        CampaignInvite[]
  contentReviews ContentReview[]
  // accessRequests are platform-scoped (not campaign-scoped)

  @@index([createdAt])
}

model Session {
  id         BigInt        @id @default(autoincrement()) @db.BigInt
  campaignId BigInt        @db.BigInt
  status     SessionStatus @default(created)
  createdAt  DateTime      @default(now())
  startedAt  DateTime?
  endedAt    DateTime?

  campaign     Campaign         @relation(fields: [campaignId], references: [id], onDelete: Restrict)
  events       Event[]
  sequence     SessionSequence?
  streamLeases StreamLease[]

  @@index([campaignId, createdAt])
}

model Character {
  id               BigInt   @id @default(autoincrement()) @db.BigInt
  campaignId       BigInt   @db.BigInt
  createdByAgentId BigInt?  @db.BigInt
  name             String   @db.VarChar(120)
  // Immutable starting sheet. Runtime vitality, focus, conditions, inventory,
  // and clocks remain event-sourced in the session log.
  sheet            Json
  createdAt        DateTime @default(now())

  campaign       Campaign        @relation(fields: [campaignId], references: [id], onDelete: Restrict)
  createdBy      Agent?          @relation("CharacterCreator", fields: [createdByAgentId], references: [id], onDelete: SetNull)
  agents         Agent[]
  contentReviews ContentReview[]

  @@index([campaignId, createdAt])
  @@index([createdByAgentId, createdAt])
}

model Account {
  id           BigInt    @id @default(autoincrement()) @db.BigInt
  // Stable identity across campaigns (agent-supplied). This is the canonical bot identity.
  botId        String    @unique @db.VarChar(120)
  name         String    @db.VarChar(120)
  // Platform-level role (what the admin approved for this account).
  // Campaign membership roles may be equal-or-lower depending on how the account joins a campaign.
  platformRole AgentRole
  createdAt    DateTime  @default(now())

  agents         Agent[]
  apiKeys        ApiKey[]
  publicKeys     AccountPublicKey[]
  accessRequests AccessRequest[]
  apiKeyClaims   ApiKeyClaim[]
  usedInvites    CampaignInvite[]
  contentReviews ContentReview[]

  @@index([platformRole, createdAt])
}

model Agent {
  id          BigInt    @id @default(autoincrement()) @db.BigInt
  accountId   BigInt    @db.BigInt
  campaignId  BigInt    @db.BigInt
  characterId BigInt?   @db.BigInt
  role        AgentRole
  name        String    @db.VarChar(120)
  createdAt   DateTime  @default(now())

  account   Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  campaign  Campaign   @relation(fields: [campaignId], references: [id], onDelete: Restrict)
  character Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)

  events            Event[]
  createdCharacters Character[]      @relation("CharacterCreator")
  createdInvites    CampaignInvite[]
  contentReviews    ContentReview[]

  @@unique([accountId, campaignId])
  @@index([accountId, createdAt])
  @@index([campaignId, createdAt])
  @@index([characterId, createdAt])
}

model ApiKey {
  id        BigInt    @id @default(autoincrement()) @db.BigInt
  accountId BigInt    @db.BigInt
  // Store only a hash (never the raw key)
  hash      String    @db.VarChar(255)
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([hash])
  @@index([accountId, createdAt])
}

model AccountPublicKey {
  id        BigInt    @id @default(autoincrement()) @db.BigInt
  accountId BigInt    @db.BigInt
  keyId     String    @unique @db.VarChar(80)
  // PEM-encoded Ed25519 public key. This is not secret.
  publicKey String    @db.Text
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  account Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  nonces  AuthNonce[]

  @@index([accountId, createdAt])
  @@index([revokedAt])
}

model AuthNonce {
  id        BigInt   @id @default(autoincrement()) @db.BigInt
  keyId     String   @db.VarChar(80)
  nonce     String   @db.VarChar(120)
  expiresAt DateTime
  createdAt DateTime @default(now())

  publicKey AccountPublicKey @relation(fields: [keyId], references: [keyId], onDelete: Cascade)

  @@unique([keyId, nonce])
  @@index([expiresAt])
}

enum AccessRequestStatus {
  pending
  approved
  denied
}

model AccessRequest {
  id            BigInt    @id @default(autoincrement()) @db.BigInt
  requestedRole AgentRole
  name          String    @db.VarChar(120)
  // Stable identity across campaigns (agent-supplied). Required for platform onboarding.
  botId         String    @db.VarChar(120)
  message       String?   @db.VarChar(1000)
  tags          Json      @default("[]")
  // Optional Ed25519 public key for redaction-safe bot auth. Not secret.
  publicKey     String?   @db.Text
  publicKeyId   String?   @db.VarChar(80)

  // Legacy poll secret retained only for old records; new onboarding uses
  // signed Ed25519 proof-of-possession and never returns a claim URL.
  // Store only a hash; return the raw token once on creation.
  pollTokenHash String    @db.VarChar(255)
  deliveredAt   DateTime?
  accountId     BigInt?   @db.BigInt
  claimedAt     DateTime?

  status       AccessRequestStatus @default(pending)
  decidedAt    DateTime?
  decisionNote String?             @db.VarChar(1000)

  createdAt DateTime @default(now())

  account Account?     @relation(fields: [accountId], references: [id], onDelete: SetNull)
  claim   ApiKeyClaim?

  @@index([status, createdAt])
  @@index([pollTokenHash])
  @@index([publicKeyId])
  @@index([botId, createdAt])
  @@index([accountId, createdAt])
}

model ApiKeyClaim {
  id              BigInt    @id @default(autoincrement()) @db.BigInt
  accessRequestId BigInt    @unique @db.BigInt
  accountId       BigInt    @db.BigInt
  tokenHash       String    @db.VarChar(255)
  createdAt       DateTime  @default(now())
  expiresAt       DateTime
  claimedAt       DateTime?

  accessRequest AccessRequest @relation(fields: [accessRequestId], references: [id], onDelete: Cascade)
  account       Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, createdAt])
  @@index([tokenHash])
  @@index([expiresAt])
}

model CampaignInvite {
  id               BigInt    @id @default(autoincrement()) @db.BigInt
  campaignId       BigInt    @db.BigInt
  createdByAgentId BigInt    @db.BigInt
  codeHash         String    @unique @db.VarChar(255)
  // Single-use invites: remainingUses starts at 1 and is decremented to 0 on join.
  remainingUses    Int       @default(1)
  createdAt        DateTime  @default(now())
  usedAt           DateTime?
  usedByAccountId  BigInt?   @db.BigInt

  campaign  Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  createdBy Agent    @relation(fields: [createdByAgentId], references: [id], onDelete: Cascade)
  usedBy    Account? @relation(fields: [usedByAccountId], references: [id], onDelete: SetNull)

  @@index([campaignId, createdAt])
  @@index([createdByAgentId, createdAt])
  @@index([remainingUses, createdAt])
}

// Append-only event log (canonical state).
model SessionSequence {
  sessionId    BigInt @id @db.BigInt
  nextSequence BigInt @db.BigInt

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Event {
  id         BigInt @id @default(autoincrement()) @db.BigInt
  campaignId BigInt @db.BigInt
  sessionId  BigInt @db.BigInt
  // Server-assigned monotonically increasing sequence per session
  sequence   BigInt @db.BigInt

  type    String @db.VarChar(80)
  // JSON payload for the event (validated by server)
  payload Json

  // Actor (optional for system events)
  agentId         BigInt? @db.BigInt
  // Client- or server-supplied retry key. Unique per actor and session.
  idempotencyKey  String? @db.VarChar(120)
  idempotencyHash String? @db.VarChar(64)

  createdAt DateTime @default(now())

  campaign       Campaign        @relation(fields: [campaignId], references: [id], onDelete: Restrict)
  session        Session         @relation(fields: [sessionId], references: [id], onDelete: Restrict)
  agent          Agent?          @relation(fields: [agentId], references: [id], onDelete: SetNull)
  contentReviews ContentReview[]

  @@unique([sessionId, sequence])
  @@unique([sessionId, agentId, idempotencyKey])
  @@index([campaignId, createdAt])
  @@index([agentId, createdAt])
  @@index([sessionId, sequence])
}

model ContentReview {
  id            BigInt   @id @default(autoincrement()) @db.BigInt
  campaignId    BigInt   @db.BigInt
  characterId   BigInt?  @db.BigInt
  eventId       BigInt?  @db.BigInt
  accountId     BigInt?  @db.BigInt
  agentId       BigInt?  @db.BigInt
  surface       String   @db.VarChar(80)
  subjectHash   String   @db.VarChar(64)
  decision      String   @db.VarChar(64)
  rightsBasis   String   @db.VarChar(32)
  policyVersion String   @db.VarChar(64)
  checkedAt     DateTime
  evidence      Json
  createdAt     DateTime @default(now())

  campaign  Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  character Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)
  event     Event?     @relation(fields: [eventId], references: [id], onDelete: SetNull)
  account   Account?   @relation(fields: [accountId], references: [id], onDelete: SetNull)
  agent     Agent?     @relation(fields: [agentId], references: [id], onDelete: SetNull)

  @@index([campaignId, createdAt])
  @@index([characterId, createdAt])
  @@index([agentId, createdAt])
  @@index([surface, createdAt])
}

// Shared, atomic rate-limit counters. Keys are SHA-256 digests, never raw input.
model RateLimitBucket {
  key       String   @id @db.VarChar(64)
  count     Int
  resetAt   DateTime
  updatedAt DateTime @updatedAt

  @@index([resetAt])
}

// Database-backed leases keep public spectator connection limits consistent
// across multiple app processes and survive neither restarts nor stale sockets.
// Expired leases are reclaimed when a new stream is acquired.
model StreamLease {
  token     String   @id @db.VarChar(64)
  sessionId BigInt   @db.BigInt
  ipHash    String   @db.VarChar(64)
  expiresAt DateTime
  createdAt DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, expiresAt])
  @@index([ipHash, expiresAt])
  @@index([expiresAt])
}
