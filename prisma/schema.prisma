// prisma/schema.prisma
// AgentQuest MVP schema (event-sourced)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// --- Core domain ---

enum AgentRole {
  gm
  player
  observer
}

enum SessionStatus {
  created
  active
  paused
  stopped
}

enum CampaignStatus {
  active
  archived
}

model Campaign {
  id     BigInt         @id @default(autoincrement()) @db.BigInt
  name   String         @db.VarChar(200)
  status CampaignStatus @default(active)

  // Campaign configuration. We keep this immutable for MVP by not providing any update endpoint
  // once sessions exist for the campaign.
  settings Json @default("{}")

  createdAt  DateTime  @default(now())
  archivedAt DateTime?

  sessions       Session[]
  characters     Character[]
  agents         Agent[]
  events         Event[]
  accessRequests AccessRequest[]

  @@index([createdAt])
}

model Session {
  id         BigInt        @id @default(autoincrement()) @db.BigInt
  campaignId BigInt        @db.BigInt
  status     SessionStatus @default(created)
  createdAt  DateTime      @default(now())
  startedAt  DateTime?
  endedAt    DateTime?

  campaign Campaign         @relation(fields: [campaignId], references: [id], onDelete: Restrict)
  events   Event[]
  sequence SessionSequence?

  @@index([campaignId, createdAt])
}

model Character {
  id               BigInt   @id @default(autoincrement()) @db.BigInt
  campaignId       BigInt   @db.BigInt
  createdByAgentId BigInt?  @db.BigInt
  name             String   @db.VarChar(120)
  createdAt        DateTime @default(now())

  campaign  Campaign @relation(fields: [campaignId], references: [id], onDelete: Restrict)
  createdBy Agent?   @relation("CharacterCreator", fields: [createdByAgentId], references: [id], onDelete: SetNull)
  agents    Agent[]

  @@index([campaignId, createdAt])
  @@index([createdByAgentId, createdAt])
}

model Agent {
  id          BigInt    @id @default(autoincrement()) @db.BigInt
  campaignId  BigInt    @db.BigInt
  characterId BigInt?   @db.BigInt
  role        AgentRole
  name        String    @db.VarChar(120)
  // Stable identity across campaigns (agent-supplied). Used for per-bot limits.
  botId       String?   @db.VarChar(120)
  createdAt   DateTime  @default(now())

  campaign  Campaign   @relation(fields: [campaignId], references: [id], onDelete: Restrict)
  character Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)

  apiKeys           ApiKey[]
  claims            ApiKeyClaim[]
  events            Event[]
  accessRequests    AccessRequest[]
  createdCharacters Character[]     @relation("CharacterCreator")

  @@index([campaignId, createdAt])
  @@index([characterId, createdAt])
  @@index([botId, createdAt])
}

model ApiKey {
  id        BigInt    @id @default(autoincrement()) @db.BigInt
  agentId   BigInt    @db.BigInt
  // Store only a hash (never the raw key)
  hash      String    @db.VarChar(255)
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([hash])
  @@index([agentId, createdAt])
}

enum AccessRequestStatus {
  pending
  approved
  denied
}

model AccessRequest {
  id            BigInt    @id @default(autoincrement()) @db.BigInt
  campaignId    BigInt    @db.BigInt
  requestedRole AgentRole
  name          String    @db.VarChar(120)
  // Optional stable identity across campaigns (agent-supplied)
  botId         String?   @db.VarChar(120)
  characterName String?   @db.VarChar(120)
  message       String?   @db.VarChar(1000)
  tags          Json      @default("[]")

  // Secret used by the requesting agent to poll for approval/claimUrl.
  // Store only a hash; return the raw token once on creation.
  pollTokenHash String    @db.VarChar(255)
  deliveredAt   DateTime?
  agentId       BigInt?   @db.BigInt
  claimedAt     DateTime?

  status       AccessRequestStatus @default(pending)
  decidedAt    DateTime?
  decisionNote String?             @db.VarChar(1000)

  createdAt DateTime @default(now())

  campaign Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  agent    Agent?       @relation(fields: [agentId], references: [id], onDelete: SetNull)
  claim    ApiKeyClaim?

  @@index([campaignId, createdAt])
  @@index([status, createdAt])
  @@index([pollTokenHash])
  @@index([botId, createdAt])
}

model ApiKeyClaim {
  id              BigInt    @id @default(autoincrement()) @db.BigInt
  accessRequestId BigInt    @unique @db.BigInt
  agentId         BigInt    @db.BigInt
  tokenHash       String    @db.VarChar(255)
  createdAt       DateTime  @default(now())
  expiresAt       DateTime
  claimedAt       DateTime?

  accessRequest AccessRequest @relation(fields: [accessRequestId], references: [id], onDelete: Cascade)
  agent         Agent         @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId, createdAt])
  @@index([tokenHash])
  @@index([expiresAt])
}

// Append-only event log (canonical state).
model SessionSequence {
  sessionId    BigInt @id @db.BigInt
  nextSequence BigInt @db.BigInt

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Event {
  id         BigInt @id @default(autoincrement()) @db.BigInt
  campaignId BigInt @db.BigInt
  sessionId  BigInt @db.BigInt
  // Server-assigned monotonically increasing sequence per session
  sequence   BigInt @db.BigInt

  type    String @db.VarChar(80)
  // JSON payload for the event (validated by server)
  payload Json

  // Actor (optional for system events)
  agentId BigInt? @db.BigInt

  createdAt DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Restrict)
  session  Session  @relation(fields: [sessionId], references: [id], onDelete: Restrict)
  agent    Agent?   @relation(fields: [agentId], references: [id], onDelete: SetNull)

  @@unique([sessionId, sequence])
  @@index([campaignId, createdAt])
  @@index([agentId, createdAt])
  @@index([sessionId, sequence])
}
